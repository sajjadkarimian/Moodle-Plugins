<div class="local-mycoursegroups">
    <div class="mb-3 d-flex align-items-center gap-2 flex-wrap">
        <span class="font-weight-bold mr-2">{{viewlabel}}</span>
        <a href="{{cardviewurl}}" class="btn btn-sm {{#viewiscard}}btn-primary{{/viewiscard}}{{^viewiscard}}btn-outline-primary{{/viewiscard}}">{{cardlabel}}</a>
        <a href="{{listviewurl}}" class="btn btn-sm {{#viewislist}}btn-primary{{/viewislist}}{{^viewislist}}btn-outline-primary{{/viewislist}}">{{listlabel}}</a>
    </div>

    {{#categories}}
    <section class="mb-4">
        {{#showcategoryheading}}<h3 class="h4 mb-3">{{categoryname}}</h3>{{/showcategoryheading}}

        {{#viewiscard}}
        <div class="row">
            {{#courses}}
            <div class="col-sm-6 col-lg-4 col-xl-3 mb-4">
                <div class="card h-100 shadow-sm">
                    {{#hasimage}}
                    <img src="{{imageurl}}" class="card-img-top" alt="{{fullname}}" style="height: 180px; object-fit: cover;">
                    {{/hasimage}}
                    {{^hasimage}}
                    <div class="card-img-top bg-light d-flex align-items-center justify-content-center text-muted" style="height: 180px;">{{noimagealt}}</div>
                    {{/hasimage}}
                    <div class="card-body d-flex flex-column">
                        <h4 class="h5 card-title"><a href="{{url}}">{{fullname}}</a></h4>
                        {{#summary}}<p class="card-text text-muted small">{{summary}}</p>{{/summary}}
                    </div>
                </div>
            </div>
            {{/courses}}
        </div>
        {{/viewiscard}}

        {{#viewislist}}
        <div class="list-group">
            {{#courses}}
            <a href="{{url}}" class="list-group-item list-group-item-action d-flex align-items-center">
                {{#hasimage}}
                <img src="{{imageurl}}" alt="{{fullname}}" style="width: 84px; height: 56px; object-fit: cover; margin-right: 1rem; border-radius: .25rem;">
                {{/hasimage}}
                <div>
                    <div class="font-weight-bold">{{fullname}}</div>
                    {{#summary}}<div class="text-muted small">{{summary}}</div>{{/summary}}
                </div>
            </a>
            {{/courses}}
        </div>
        {{/viewislist}}
    </section>
    {{/categories}}

    {{^categories}}
    <p>{{#str}} nocourses, local_mycoursegroups {{/str}}</p>
    {{/categories}}
</div>
